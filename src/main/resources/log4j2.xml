<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="[%d{HH:mm:ss}] [%-5level] [%logger{36}]\t[%F - %M]: %msg %n" />
        </Console>
        <File name="SQLFileLogger" fileName="logs/sql.log">
            <PatternLayout pattern="[%d{HH:mm:ss}] [%-5level]: %msg %n" />
        </File>
        <TextAreaAppender name="TextAreaAppender">
            <PatternLayout pattern="[%d{HH:mm:ss}] [%-5level] [%logger{36}] [%F - %M]: %msg %n" />
        </TextAreaAppender>
    </Appenders>
    <Loggers>
        <Logger name="com.kjersti.astryx.sql" level="debug" additivity="false">
            <AppenderRef ref="SQLFileLogger" />
        </Logger>
        <Root level="info">
            <AppenderRef ref="Console" />
            <AppenderRef ref="TextAreaAppender" />
        </Root>
    </Loggers>
</Configuration>